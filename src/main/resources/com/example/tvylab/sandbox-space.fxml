<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane dividerPositions="0.25" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tvylab.sandbox.SandboxSpace">

    <items>
        <!-- LEFT PANEL -->
        <VBox fx:id="menuBox" maxWidth="-Infinity" minWidth="0.0" prefWidth="250.0" spacing="10.0">

            <children>
                <!-- BACK BUTTON -->
                <Button fx:id="backBtn" maxWidth="1.7976931348623157E308" minHeight="40.0" onAction="#onBackPressed" text="BACK" />

                <!-- SCROLLABLE AREA -->
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">

                    <content>
                        <VBox fx:id="gateSpace" maxWidth="1.7976931348623157E308" spacing="8.0">

                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>

                            <children>
                                <ComboBox fx:id="gates" maxWidth="1.7976931348623157E308" promptText="GATES" />

                                <ComboBox fx:id="pins" maxWidth="1.7976931348623157E308" promptText="IO" />
                            </children>

                        </VBox>
                    </content>
                </ScrollPane>

                <!-- DELETE CHECKBOX -->
                <CheckBox fx:id="deleteToggle" text="Delete">
                    <padding>
                        <Insets left="10.0" />
                    </padding>
                </CheckBox>

                <!-- SAVE BUTTON -->
                <Button fx:id="saveBtn" maxWidth="1.7976931348623157E308" minHeight="40.0" onAction="#onSavePressed" text="SAVE" />
            </children>
        </VBox>

        <!-- RIGHT PANEL -->
        <Pane fx:id="sandboxPane" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" />

    </items>
</SplitPane>
