<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tvylab.lessons.InputLessonController">

    <!-- TOP -->
    <top>
        <StackPane>
            <children>
                <Button text="BACK" onAction="#onBackPressed" StackPane.alignment="CENTER_LEFT">
                    <StackPane.margin>
                        <Insets left="10" top="10" bottom="10"/>
                    </StackPane.margin>
                </Button>

                <Label text="Lekce: Co je vstup" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            </children>
        </StackPane>
    </top>

    <!-- CENTER -->
    <center>
        <GridPane>
            <columnConstraints>
                <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
            </columnConstraints>

            <rowConstraints>
                <RowConstraints percentHeight="70"/>
                <RowConstraints percentHeight="30"/>
            </rowConstraints>

            <children>

                <!-- TEXT -->
                <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="10" left="10" right="10"/>
                    </padding>

                    <Label text="Co je to vstup?"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Label wrapText="true" maxWidth="Infinity"
                           text="Vstup (input) je místo, odkud do logického obvodu přichází signál."/>

                    <Label wrapText="true" maxWidth="Infinity"
                           text="Signál může mít dvě hodnoty: 0 (vypnuto) nebo 1 (zapnuto)."/>

                    <Label wrapText="true" maxWidth="Infinity"
                           text="Klikni na vstup vpravo a sleduj změnu výstupu."/>
                </VBox>

                <!-- SIMULATION -->
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <padding>
                        <Insets top="10" right="10"/>
                    </padding>

                    <Label text="Klikni na vstup:"
                           style="-fx-font-style: italic;"/>

                    <Pane fx:id="simulationPane"
                          prefHeight="300"
                          styleClass="simulation-pane"/>
                </VBox>

                <!-- QUIZ -->
                <VBox spacing="10" GridPane.columnSpan="2" GridPane.rowIndex="1">
                    <padding>
                        <Insets top="10" left="10" right="10" bottom="10"/>
                    </padding>

                    <Label text="Otázka:" style="-fx-font-weight: bold;"/>
                    <Label text="Co se stane, když nastavíš vstup na 1?"/>

                    <RadioButton text="Výstup bude 1">
                        <toggleGroup>
                            <ToggleGroup fx:id="quizGroup"/>
                        </toggleGroup>
                    </RadioButton>

                    <RadioButton text="Nic se nestane" toggleGroup="$quizGroup"/>
                    <RadioButton text="Výstup bude 0" toggleGroup="$quizGroup"/>

                    <Button text="Zkontrolovat" onAction="#onCheckAnswer"/>
                </VBox>

            </children>
        </GridPane>
    </center>

</BorderPane>